# ---- Required ----

# Your OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# ---- Optional ----

# Model used as judge for evaluating rule scores (default: openai/gpt-5-nano)
# JUDGE_MODEL=openai/gpt-5-nano

# Path to the SQLite database file (default: ./results.db)
# DB_PATH=./results.db
